        <mxCell id="cmp-v1-6" value="&lt;font color=&#34;#ef4444&#34;&gt;✗&lt;/font&gt;  &lt;b&gt;Output:&lt;/b&gt; Developer pushes manually. No standardized branch." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;" vertex="1" parent="1">
