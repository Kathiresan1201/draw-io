        <mxCell id="v2-bb-direct" value="&lt;b&gt;Bitbucket&lt;/b&gt;&lt;br&gt;&lt;font style=&#34;font-size:8px&#34; color=&#34;#999&#34;&gt;Direct access via RHDH — no PAT/Vault&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#deebff;strokeColor=#2684FF;strokeWidth=1.5;fontSize=10;" vertex="1" parent="1">
