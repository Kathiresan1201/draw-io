        </mxCell>
        <mxCell id="cmp-v1-2" value="&lt;font color=&#34;#ef4444&#34;&gt;✗&lt;/font&gt;  &lt;b&gt;Analysis:&lt;/b&gt; MTA generates static report. Developer reads manually." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;" vertex="1" parent="1">
