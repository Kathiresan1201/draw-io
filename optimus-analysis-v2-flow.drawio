        <mxCell id="v2-b4" value="✓ One flow: trigger to container-ready branch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#deebff;strokeColor=#90caf9;fontSize=10;fontColor=#0d47a1;align=center;" vertex="1" parent="1">
