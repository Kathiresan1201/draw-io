        </mxCell>
        <mxCell id="cmp-v1-3" value="&lt;font color=&#34;#ef4444&#34;&gt;✗&lt;/font&gt;  &lt;b&gt;Code changes:&lt;/b&gt; Developer manually applies fixes, switching between report and IDE." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;" vertex="1" parent="1">
