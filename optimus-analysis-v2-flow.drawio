        <!-- ====== BENEFITS ====== -->
        <mxCell id="v2-b1" value="✓ No PAT/Vault setup — direct from Orion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#a5d6a7;fontSize=10;fontColor=#2e7d32;align=center;" vertex="1" parent="1">
